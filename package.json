{
  "name": "lan-helper",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "powershell -ExecutionPolicy Bypass -File tools/build_tauri_release_clean.ps1",
    "adapter:validate": "powershell -ExecutionPolicy Bypass -File tools/validate_adapter_registry.ps1",
    "release:package": "powershell -ExecutionPolicy Bypass -File tools/prepare_v0_1_release_package.ps1",
    "release:package:verify": "powershell -ExecutionPolicy Bypass -File tools/verify_v0_1_release_package.ps1",
    "release:gate": "powershell -ExecutionPolicy Bypass -File tools/run_v0_1_release_gate.ps1 -AppendLog",
    "release:preflight": "powershell -ExecutionPolicy Bypass -File tools/release_preflight.ps1",
    "release:preflight:full": "powershell -ExecutionPolicy Bypass -File tools/release_preflight.ps1 -FullBuild",
    "release:gate:v031": "powershell -ExecutionPolicy Bypass -File tools/run_v0_3_1_release_gate.ps1",
    "tauri:build:raw": "tauri build",
    "release:zip": "powershell -ExecutionPolicy Bypass -File tools/prepare_windows_x64_zip.ps1",
    "release:zip:verify": "powershell -ExecutionPolicy Bypass -File tools/verify_windows_x64_zip.ps1",
    "release:github:update": "powershell -ExecutionPolicy Bypass -File tools/update_github_release_v0_1.ps1",
    "regression:dual-machine:verify": "node tools/verify_dual_machine_regression_evidence.cjs",
    "network:diagnostic:verify": "node tools/verify_network_diagnostic_ui.cjs",
