{
  "game_id": "terraria",
  "display_name": "Terraria",
  "steam_appid": "105600",
  "capabilities": [
    "lan",
    "ip_join",
    "dedicated_server"
  ],
  "executables": [
    "Terraria.exe",
    "TerrariaServer.exe"
  ],
  "default_ports": [
    7777
  ],
  "launch_profiles": [
    {
      "id": "client",
      "name": "启动游戏客户端",
      "type": "client",
      "exe": "Terraria.exe"
    },
    {
      "id": "server",
      "name": "启动本地服务端",
      "type": "server",
      "exe": "TerrariaServer.exe",
      "config_fields": [
        {
          "id": "world_choice",
          "label": "世界编号",
          "type": "number",
          "default_value": "1",
          "required": true,
          "help": "联机助手会按本机 Terraria Worlds 目录中的 .wld 文件排序后选择，默认 1。"
        },
        {
          "id": "world_path",
          "label": "世界文件路径（可选）",
          "type": "text",
          "default_value": "",
          "required": false,
          "help": "如果世界编号不准确，可填写完整 .wld 路径，例如 C:\\Users\\你\\Documents\\My Games\\Terraria\\Worlds\\xxx.wld。"
        },
        {
          "id": "max_players",
          "label": "最大人数",
          "type": "number",
          "default_value": "8",
          "required": true
        },
        {
          "id": "port",
          "label": "端口",
          "type": "number",
          "default_value": "7777",
          "required": true
        },
        {
          "id": "auto_forward",
          "label": "自动端口转发 y/n",
          "type": "select",
          "default_value": "y",
          "required": true,
          "options": [
            "y",
            "n"
          ],
          "help": "使用虚拟局域网时一般填 n 也可以；公网开服可尝试 y。"
        },
        {
          "id": "password",
          "label": "服务器密码",
          "type": "password",
          "default_value": "",
          "required": false,
          "help": "留空表示不设置密码。"
        }
      ]
    },
    {
      "id": "docs",
      "name": "查看连接说明",
      "type": "docs"
    }
  ],
  "multiplayer_conversion": {
    "capability": "hidden_dedicated_server",
    "methods": [
      "virtual_lan",
      "dedicated_server_launcher"
    ],
    "can_convert_to_lan": true,
    "risk_level": "low",
    "notes": [
      "Terraria 支持 IP 直连，并提供 TerrariaServer.exe。",
      "联机助手可负责 n2n 组网、后台启动本地服务端、端口诊断和邀请信息。"
    ],
    "required_components": [
      "n2n/Radmin/已有局域网",
      "TerrariaServer.exe",
      "7777 或自定义游戏端口"
    ]
  },
  "network_type": "dedicated_server",
  "connection_plan": {
    "summary": "房主启动 TerrariaServer.exe，双方进入同一虚拟局域网后，好友连接房主虚拟 IP:7777。",
    "host_role": "房主在联机助手内启动 Terraria 本地服务端，并保持 n2n edge 运行。",
    "join_role": "加入者启动 n2n edge 后，在 Terraria 中选择 Join via IP，连接房主虚拟 IP 和端口。",
    "default_join_host": "房主虚拟 IP",
    "default_join_port": 7777,
    "requires_virtual_lan": true,
    "requires_tcp_port_proxy": false,
    "requires_udp_broadcast_bridge": false,
    "requires_dedicated_server": true,
    "invite_template": [
      "双方填写相同 community、密钥和 supernode。",
      "房主虚拟 IP 通常为 10.10.10.2，加入者使用不同虚拟 IP。",
      "房主启动 Terraria 服务端并确认 7777 端口监听。",
      "加入者在 Terraria 中 Join via IP：房主虚拟 IP:7777。"
    ],
    "troubleshooting": [
      "先确认 n2n 诊断出现 ACK/PONG。",
      "确认 127.0.0.1:7777 和房主虚拟 IP:7777 都可达。",
      "如果服务端只监听本地地址，可启用 TCP 端口代理。"
    ]
  }
}
